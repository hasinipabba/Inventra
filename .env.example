# External barcode/product lookup providers (server-side only — never exposed to the browser).
# Open Food Facts needs no key and is always enabled.
# UPCitemdb works on the free trial endpoint without a key; add one for the paid tier.
UPCITEMDB_API_KEY=
CRON_SECRET=
# Optional additional providers — leave blank to disable.
BARCODE_LOOKUP_API_KEY=
EAN_SEARCH_API_KEY=

# REQUIRED — Postgres connection string (e.g. from Neon, Vercel Postgres, or Supabase).
# All app data (products, staff, attendance, users, notifications, and the
# login/signup accounts) is stored here. Tables are created automatically
# and seeded with demo data on first use — no manual migration step needed.
DATABASE_URL=

# Secret used to sign session cookies (lib/session.ts). Falls back to a dev
# default if unset — set a long random value before deploying.
AUTH_SECRET=

# Google Sign-In (OAuth 2.0). Create credentials at
# https://console.cloud.google.com/apis/credentials — "Web application" type.
# Authorized redirect URI must exactly match: <your-domain>/api/auth/google/callback
# (e.g. http://localhost:3000/api/auth/google/callback for local dev).
# Leave blank to disable the Google button — email/password login still works.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Only needed if your real callback URL differs from your request origin
# (e.g. behind a proxy) — otherwise this is derived automatically.
GOOGLE_REDIRECT_URI=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=



